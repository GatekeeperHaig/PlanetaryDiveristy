{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Stellaris Localisation",
    "scopeName": "stellaris-loc.injection",
    "injectionSelector": "L:source.yaml",
    "patterns": [
        { "include": "#loc-key" },
        { "include": "#color-reset" },
        { "include": "#color-red" },
        { "include": "#color-green" },
        { "include": "#color-yellow" },
        { "include": "#color-blue" },
        { "include": "#color-magenta" },
        { "include": "#color-purple" },
        { "include": "#color-orange" },
        { "include": "#color-head" },
        { "include": "#color-gray" },
        { "include": "#color-white" },
        { "include": "#color-teal" },
        { "include": "#color-shadow" },
        { "include": "#color-energy" },
        { "include": "#color-other" },
        { "include": "#newline-escape" },
        { "include": "#icon-ref" },
        { "include": "#scope-ref" },
        { "include": "#variable-engine" },
        { "include": "#variable-ref" }
    ],
    "repository": {
        "loc-key": {
            "comment": "Stellaris loc line: <key>[:N] \"...\" — anchored at line start, lookahead requires the quoted value so this does not fire on plain YAML mappings.",
            "match": "^(\\s*)([A-Za-z_][A-Za-z0-9_.]*?)(:)(\\d*)(?=\\s+\")",
            "captures": {
                "2": { "name": "entity.name.tag.loc-key.stellaris-loc" },
                "3": { "name": "punctuation.separator.key-value.stellaris-loc" },
                "4": { "name": "constant.numeric.version.stellaris-loc" }
            }
        },
        "color-reset": {
            "match": "§!",
            "name": "constant.character.escape.color.reset.stellaris-loc"
        },
        "color-red": {
            "match": "§[Rr]",
            "name": "constant.character.escape.color.red.stellaris-loc"
        },
        "color-green": {
            "match": "§[Gg]",
            "name": "constant.character.escape.color.green.stellaris-loc"
        },
        "color-yellow": {
            "match": "§[Yy]",
            "name": "constant.character.escape.color.yellow.stellaris-loc"
        },
        "color-blue": {
            "match": "§[Bb]",
            "name": "constant.character.escape.color.blue.stellaris-loc"
        },
        "color-magenta": {
            "match": "§[Mm]",
            "name": "constant.character.escape.color.magenta.stellaris-loc"
        },
        "color-purple": {
            "match": "§[Pp]",
            "name": "constant.character.escape.color.purple.stellaris-loc"
        },
        "color-orange": {
            "match": "§[Oo]",
            "name": "constant.character.escape.color.orange.stellaris-loc"
        },
        "color-head": {
            "match": "§[Hh]",
            "name": "constant.character.escape.color.head.stellaris-loc"
        },
        "color-gray": {
            "match": "§[Ll]",
            "name": "constant.character.escape.color.gray.stellaris-loc"
        },
        "color-white": {
            "match": "§[Ww]",
            "name": "constant.character.escape.color.white.stellaris-loc"
        },
        "color-teal": {
            "match": "§[Tt]",
            "name": "constant.character.escape.color.teal.stellaris-loc"
        },
        "color-shadow": {
            "match": "§[Ss]",
            "name": "constant.character.escape.color.shadow.stellaris-loc"
        },
        "color-energy": {
            "match": "§[Ee]",
            "name": "constant.character.escape.color.energy.stellaris-loc"
        },
        "color-other": {
            "comment": "Fallback for any §X tag not enumerated above (player-index colours §0–§9, custom letters).",
            "match": "§[A-Za-z0-9]",
            "name": "constant.character.escape.color.other.stellaris-loc"
        },
        "newline-escape": {
            "match": "\\\\n",
            "name": "constant.character.escape.newline.stellaris-loc"
        },
        "icon-ref": {
            "comment": "£icon£ or £icon|frame£ inline icon embed.",
            "match": "(£)([A-Za-z_][A-Za-z0-9_]*)(?:(\\|)([A-Za-z0-9]+))?(£)",
            "captures": {
                "1": { "name": "punctuation.definition.icon.begin.stellaris-loc" },
                "2": { "name": "support.constant.icon.stellaris-loc" },
                "3": { "name": "punctuation.separator.icon-frame.stellaris-loc" },
                "4": { "name": "constant.numeric.icon-frame.stellaris-loc" },
                "5": { "name": "punctuation.definition.icon.end.stellaris-loc" }
            }
        },
        "scope-ref": {
            "comment": "Bracketed scope/script ref. Begin lookahead requires a known scope root or a quoted namespace ref so we do not collide with YAML flow sequences like [1, 2, 3].",
            "begin": "\\[(?=(?:Root|Prev|PrevPrev|PrevPrevPrev|PrevPrevPrevPrev|This|From|FromFrom|FromFromFrom|FromFromFromFrom|Owner|Capital|Planet|Country|System|Leader|Pop|Species|Ship|Fleet|Star|Actor|Recipient|Third|Solar_System|Sector|Megastructure|Starbase|Ambient_Object|Army|Branch_Office|Federation|Galactic_Object|Get[A-Z])\\b|')",
            "end": "\\]",
            "beginCaptures": {
                "0": { "name": "punctuation.section.scope.begin.stellaris-loc" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.section.scope.end.stellaris-loc" }
            },
            "name": "meta.scope-ref.stellaris-loc",
            "patterns": [
                {
                    "comment": "Namespace ref like 'concept:foo', 'civic:bar'.",
                    "match": "(')([A-Za-z_][A-Za-z0-9_]*)(:)([A-Za-z0-9_]+)(')",
                    "captures": {
                        "1": { "name": "punctuation.definition.string.begin.stellaris-loc" },
                        "2": { "name": "entity.name.namespace.stellaris-loc" },
                        "3": { "name": "punctuation.separator.namespace.stellaris-loc" },
                        "4": { "name": "variable.other.member.stellaris-loc" },
                        "5": { "name": "punctuation.definition.string.end.stellaris-loc" }
                    }
                },
                {
                    "match": "\\b(Root|Prev|PrevPrev|PrevPrevPrev|PrevPrevPrevPrev|This|From|FromFrom|FromFromFrom|FromFromFromFrom|Owner|Capital|Planet|Country|System|Leader|Pop|Species|Ship|Fleet|Star|Actor|Recipient|Third|Solar_System|Sector|Megastructure|Starbase|Ambient_Object|Army|Branch_Office|Federation|Galactic_Object)\\b",
                    "name": "support.class.scope-root.stellaris-loc"
                },
                {
                    "match": "\\.",
                    "name": "punctuation.accessor.stellaris-loc"
                },
                {
                    "comment": "Script-call segment after a scope root or another call (e.g. GetName, GetSpeciesNamePlural).",
                    "match": "[A-Za-z_][A-Za-z0-9_]*",
                    "name": "entity.name.function.scope-call.stellaris-loc"
                }
            ]
        },
        "variable-engine": {
            "comment": "Engine-defined all-caps token: $TRIGGER_FAIL$, $NEW_LINE$, $PLANET|Y$, $MOD_POP_GROWTH_SPEED_REDUCTION$.",
            "match": "(\\$)([A-Z][A-Z0-9_]*)(?:(\\|)([A-Za-z0-9]+))?(\\$)",
            "captures": {
                "1": { "name": "punctuation.definition.variable.begin.stellaris-loc" },
                "2": { "name": "support.variable.engine.stellaris-loc" },
                "3": { "name": "punctuation.separator.var-format.stellaris-loc" },
                "4": { "name": "constant.other.format-flag.stellaris-loc" },
                "5": { "name": "punctuation.definition.variable.end.stellaris-loc" }
            }
        },
        "variable-ref": {
            "comment": "Loc-key reference: $district_pd_aw_necro$, $r_energy$, $pop$. Optional |format suffix.",
            "match": "(\\$)([A-Za-z_][A-Za-z0-9_]*)(?:(\\|)([A-Za-z0-9]+))?(\\$)",
            "captures": {
                "1": { "name": "punctuation.definition.variable.begin.stellaris-loc" },
                "2": { "name": "variable.other.loc-ref.stellaris-loc" },
                "3": { "name": "punctuation.separator.var-format.stellaris-loc" },
                "4": { "name": "constant.other.format-flag.stellaris-loc" },
                "5": { "name": "punctuation.definition.variable.end.stellaris-loc" }
            }
        }
    }
}
