#####    Volcanic Planets    ######
@ringworld_segment_size = 50

###Volcanic
#Ash
entity = {
	name = "ash_planet_01_entity"
	pdxmesh = "planet_clouded_mesh"

	meshsettings = {
		name = "planet_geosphereShape"
		shader = "PdxMeshPlanetEmissive"
		texture_diffuse = "pd_ash_01_diffuse.dds"
		texture_normal = "pd_ash_01_normal.dds"
		texture_specular = "pd_ash_01_spec.dds"
	}

	##cloud texture override
	meshsettings = {
		name = "clouds_geosphereShape"
		texture_diffuse = "clouds_smog_01_diffuse.dds"
		texture_normal = "nonormal.dds"
		texture_specular = "nospec.dds"
	}

	##cloud shadow texture override
	meshsettings = {
		name = "clouds_shadow_geosphereShape"
		texture_diffuse = "clouds_smog_shadow_01_diffuse.dds"
		texture_normal = "nonormal.dds"
		texture_specular = "nospec.dds"
	}

	default_state = "idle"
	playback_rate = -1.0 # Rotation is reversed
	state = { name = "idle" animation = "idle" time_offset = { 0 100 }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_molten_world_a" } }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_molten_world_b" } }
	}
}
