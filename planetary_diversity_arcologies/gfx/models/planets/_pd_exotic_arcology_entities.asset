# Cryogenic Exotic Arcology Planet Entities
# Layered pattern mirroring planetary_diversity_arcologies: each city planet entity is a locator that attaches a per-flavor planet surface mesh plus the flavor's cloud overlay and any special overlays (fortress shield, commercial billboards).
# Overlay entities (clouds / shield / billboards) use a generic pd_exotic_* prefix so methane and future exotic arcology classes can reuse them without duplicating the chain; the DDS filenames they reference live in PD MA and are loaded whenever the garden / fortress / commercial flavors fire (those decisions gate on has_global_flag = planetarydiversitymorearcologies).

####### Cloud overlays #######

# Plain ammonia clouds; PD-exotics native ammonia cloud texture.
entity = {
	name = "pd_exotic_planet_cloud_mesh"
	pdxmesh = "ma_planet_cloud_mesh"
	scale = 0.985
	meshsettings = {
		name = "clouds_geosphereShape"
		texture_diffuse = "pd_ammonia_planet_clouds.dds"
		texture_normal = "nonormal.dds"
		texture_specular = "nospec.dds"
		shader = "AlphaBlend_00"
	}
	meshsettings = {
		name = "clouds_shadow_geosphereShape"
		texture_diffuse = "pd_ammonia_planet_clouds_shadow.dds"
		texture_normal = "nonormal.dds"
		texture_specular = "nospec.dds"
		shader = "AlphaBlend_00"
	}
	default_state = "idle"
	state = { name = "idle" animation = "idle" time_offset = { 0 100 }
		animation_speed = 0.6
	}
}

