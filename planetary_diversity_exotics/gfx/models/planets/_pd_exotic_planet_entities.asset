##### Cryogenic Exotic Planet Entities ######

entity = {
	name = "methane_planet_01_entity"
	pdxmesh = "planet_clouded_mesh"

	meshsettings = {
		name = "planet_geosphereShape"
		texture_diffuse = "methane_01_diffuse.dds"
		texture_normal = "methane_01_normal.dds"
		texture_specular = "methane_01_specular.dds"
	}

	meshsettings = {
		name = "clouds_geosphereShape"
		texture_diffuse = "pd_methane_planet_clouds.dds"
		texture_normal = "nonormal.dds"
		texture_specular = "nospec.dds"
	}

	meshsettings = {
		name = "clouds_shadow_geosphereShape"
		texture_diffuse = "pd_methane_planet_clouds_shadow.dds"
		texture_normal = "nonormal.dds"
		texture_specular = "nospec.dds"
	}

	default_state = "idle"
	state = { name = "idle" animation = "idle" time_offset = { 0 100 }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_planet_class" } }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_planet_class_02" } }
	}
}

