entity = {
	name = "pd_ammonia_fortress_city_planet_01_entity"
	locator = { name = "planetloc" position = { 0 0 0 } rotation = { 0 0 0 } }
	default_state = "idle"
	playback_rate = 1.0
	state = { name = "idle" time_offset = { 0 100 }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_city_planet" } }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_city_planet_flyby" } }
	}
	attach = { "planetloc" = "pd_ammonia_city_planet_mesh" }
	attach = { "planetloc" = "pd_exotic_fortress_planet_cloud_mesh" }
	attach = { "planetloc" = "pd_exotic_planet_shield_effect_entity" }
	game_data = {
		shader_type = ship
		emissive_recolor_crunch = 5.0
	}
	scale = 1.0
}

