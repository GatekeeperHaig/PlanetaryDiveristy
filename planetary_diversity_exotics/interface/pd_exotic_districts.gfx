	}

	# Rectangle grid pips (one slim rectangle per built district in the grid strip).
	# DDS files are 3-frame strips (normal/hover/pressed); noOfFrames = 3 plus pulsing animation block matches vanilla farming/mining/generator.

	spriteType = {
		name = "GFX_district_pdexotic_cryo_riftvent_box_icon_rectangle"
		textureFile = "gfx/interface/icons/districts/grid_box/district_pdexotic_cryo_riftvent_rectangle.dds"
		effectFile = "gfx/FX/buttonstate_onlydisable.shader"
		noOfFrames = 3
		animation = {
			animationmaskfile = "gfx/interface/icons/districts/grid_box/default_animated_mask.dds"
			animationtexturefile = "gfx/interface/icons/districts/grid_box/default_animated_texture.dds"
			animationrotation = 90.0
			animationlooping = yes
			animationtime = 2.0
			animationdelay = 0.0
			animationblendmode = "add"
			animationtype = "pulsing"
			animationrotationoffset = { x = 0.0 y = 0.0 }
			animationtexturescale = { x = 1.0 y = 1.0 }
		}
	}

