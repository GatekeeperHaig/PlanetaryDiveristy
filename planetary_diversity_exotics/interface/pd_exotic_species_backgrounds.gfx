# Registers the species-selection background sprite for each cryophile preference trait. Vanilla topbar_species_view.gfx defines GFX_species_selected_background_trait_pc_<X>_preference for all built-in preferences; without these explicit entries the panel renders empty when a player species using the trait as its primary preference is selected. Both DDS paths are PD-owned placeholders (ammonia seeded from vanilla arctic, methane seeded from vanilla alpine) — drop dedicated art over the DDS at the same path/name to upgrade.

spriteTypes = {
	spriteType = {
		name = "GFX_species_selected_background_trait_pc_pd_ammonia_preference"
		texturefile = "gfx/portraits/species_preview_backgrounds/species_preview_bg_pd_ammonia.dds"
	}
	spriteType = {
		name = "GFX_species_selected_background_trait_pc_pd_methane_preference"
		texturefile = "gfx/portraits/species_preview_backgrounds/species_preview_bg_pd_methane.dds"
	}
	spriteType = {
		name = "GFX_species_selected_background_trait_pc_pd_nitrogen_preference"
		texturefile = "gfx/portraits/species_preview_backgrounds/species_preview_bg_pd_nitrogen.dds"
	}
}
