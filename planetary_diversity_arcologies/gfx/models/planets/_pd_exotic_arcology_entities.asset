####### Fortress orbital shield overlay #######

entity = {
	name = "pd_exotic_planet_shield_effect_entity"
	pdxmesh = "planet_shield_effect_mesh"
	default_state = "idle"
	state = { name = "idle" state_time = 5
		start_event = { node = root particle = "planet_shield_effect" keep_particle = yes trigger_once = yes }
	}
	game_data = {
		shader_type = ship
		emissive_recolor_crunch = 5.0
		bloom_factor = 1.2
		uv_animation_speed = 2
		uv_animation_direction = { 0.0 -0.02 }
	}
	locator = { name = "root" position = { 0 0 0 } }
	scale = 1.03
}

####### Commercial billboard overlays #######
# Four animated ad-band layers, each composed of a locator that attaches a highlight + lowlight cloud sphere.
# Texture and animation settings mirror PD MA's pd_commercial_planet_billboard_*_mesh chain.

entity = {
	name = "pd_exotic_commercial_planet_billboard_mesh"
	pdxmesh = "locator_mesh"
	attach = { root = pd_exotic_commercial_planet_billboard_mesh_highlight }
	attach = { root = pd_exotic_commercial_planet_billboard_mesh_lowlight }
}
entity = {
	name = "pd_exotic_commercial_planet_billboard_mesh_highlight"
	pdxmesh = "ma_planet_cloud_mesh"
	scale = 0.995
	meshsettings = {
		name = "clouds_geosphereShape"
		texture_diffuse = "cloud_commercial_billboards_highlight_diffuse.dds"
		texture_normal = "cloud_commercial_billboards_normal.dds"
		texture_specular = "cloud_commercial_billboards_spec.dds"
		shader = "PdxMeshAlphaAdditiveAnimateUV"
	}
	meshsettings = {
		name = "clouds_shadow_geosphereShape"
		texture_diffuse = "noalpha.dds"
		texture_normal = "nonormal.dds"
		texture_specular = "nospec.dds"
		shader = "PdxMeshAlphaAdditive"
	}
	default_state = "idle"
	state = { name = "idle" animation = "idle"
		animation_speed = 0.50
	}
	game_data = {
		uv_animation_direction = { 1 0 }
		uv_animation_speed = 0.01
		bloom_factor = 0.75
	}
}
entity = {
	name = "pd_exotic_commercial_planet_billboard_mesh_lowlight"
	pdxmesh = "ma_planet_cloud_mesh"
	scale = 0.995
	meshsettings = {
		name = "clouds_geosphereShape"
		texture_diffuse = "cloud_commercial_billboards_lowlight_diffuse.dds"
		texture_normal = "cloud_commercial_billboards_normal.dds"
		texture_specular = "cloud_commercial_billboards_spec.dds"
		shader = "PdxMeshAlphaAdditiveAnimateUV"
	}
	meshsettings = {
		name = "clouds_shadow_geosphereShape"
		texture_diffuse = "noalpha.dds"
		texture_normal = "nonormal.dds"
		texture_specular = "nospec.dds"
		shader = "PdxMeshAlphaAdditive"
	}
	default_state = "idle"
	state = { name = "idle" animation = "idle"
		animation_speed = 0.50
	}
	game_data = {
		uv_animation_direction = { 1 0 }
		uv_animation_speed = 0.01
		bloom_factor = 1.25
	}
}

